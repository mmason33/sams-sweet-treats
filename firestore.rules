rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /menuItems/{item} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
